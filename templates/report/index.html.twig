{% extends 'base.html.twig' %}

{% block title %}Signalements{% endblock %}

{% block body %}
    <div class="page-intro">
        <h1 class="page-title">Signalements</h1>
        <p class="page-subtitle">Liste paginée avec filtres par période, gravité, type de situation, conducteur ou bus. Cliquez sur une ligne pour ouvrir la fiche (lecture seule).</p>
    </div>

    <section class="panel report-filters" aria-labelledby="report-filters-heading">
        <div class="panel__header">
            <h2 class="panel__title" id="report-filters-heading">Filtres</h2>
        </div>
        <form method="get" action="{{ path('app_report_index') }}" class="report-filter-form">
            <div class="report-filter-form__grid">
                <div class="form-field-spaced mb-0">
                    <label for="filter-period">Période (date de création)</label>
                    <select id="filter-period" name="period">
                        <option value="" {{ filter_period == '' ? 'selected' }}>Toute la période</option>
                        <option value="7d" {{ filter_period == '7d' ? 'selected' }}>7 derniers jours</option>
                        <option value="30d" {{ filter_period == '30d' ? 'selected' }}>30 derniers jours</option>
                    </select>
                </div>
                <div class="form-field-spaced mb-0">
                    <label for="filter-severity">Gravité</label>
                    <select id="filter-severity" name="severity">
                        <option value="">Toutes</option>
                        {% for s in severity_options %}
                            <option value="{{ s }}" {{ filter_severity == s ? 'selected' }}>{{ s }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-field-spaced mb-0">
                    <label for="filter-situation-type">Type de situation</label>
                    <select id="filter-situation-type" name="situation_type">
                        <option value="">Tous</option>
                        {% for c in situation_type_options %}
                            <option value="{{ c }}" {{ filter_situation_type == c ? 'selected' }}>{{ c }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-field-spaced mb-0">
                    <label for="filter-driver">Identifiant conducteur</label>
                    <input id="filter-driver" type="number" name="driver_id" min="1" step="1" value="{{ filter_driver_id ?: '' }}" placeholder="ex. 12" autocomplete="off">
                </div>
                <div class="form-field-spaced mb-0">
                    <label for="filter-bus">Identifiant bus</label>
                    <input id="filter-bus" type="number" name="bus_id" min="1" step="1" value="{{ filter_bus_id ?: '' }}" placeholder="ex. 5" autocomplete="off">
                </div>
            </div>
            <div class="stack-actions report-filter-form__actions">
                <button type="submit" class="btn">Appliquer les filtres</button>
                <a href="{{ path('app_report_index') }}" class="btn btn--secondary">Réinitialiser</a>
            </div>
        </form>
    </section>

    <p class="report-list-meta" role="status">
        {% if report_list_total == 0 %}
            Aucun signalement ne correspond aux critères.
        {% else %}
            {{ report_list_total }} signalement{{ report_list_total > 1 ? 's' }} · page {{ report_list_page }} sur {{ report_list_total_pages }}
        {% endif %}
    </p>

    <div class="table-wrap">
        <table class="table report-list-table" data-controller="report-list-rows">
            <thead>
                <tr>
                    <th scope="col">Id</th>
                    <th scope="col">Description</th>
                    <th scope="col">Gravité</th>
                    <th scope="col">Type de situation</th>
                    <th scope="col">Conducteur</th>
                    <th scope="col">Bus</th>
                    <th scope="col">Date du fait</th>
                    <th scope="col">Créé le</th>
                </tr>
            </thead>
            <tbody>
            {% for report in reports %}
                {% set show_url = path('app_report_show', { id: report.id }) %}
                <tr
                    class="report-list-row"
                    data-report-href="{{ show_url }}"
                    tabindex="0"
                    aria-label="Ouvrir le signalement n°{{ report.id }}"
                >
                    <td><span class="report-list-row__id">{{ report.id }}</span></td>
                    <td>{{ report.description|length > 120 ? report.description|slice(0, 120) ~ '…' : report.description }}</td>
                    <td>
                        <span class="report-shortlist__severity {{ {
                            'high': 'report-shortlist__severity--high',
                            'critical': 'report-shortlist__severity--critical',
                            'medium': 'report-shortlist__severity--medium',
                            'low': 'report-shortlist__severity--low',
                            'positive': 'report-shortlist__severity--low',
                        }[report.severity|default('')|lower]|default('') }}">{{ report.severity }}</span>
                    </td>
                    <td>{{ report.situationType }}</td>
                    <td>{{ report.driver ? '#' ~ report.driver.id : '—' }}</td>
                    <td>{{ report.bus ? '#' ~ report.bus.id : '—' }}</td>
                    <td>{% set tripWhen = report.incidentDate ?? report.reportDate %}{{ tripWhen ? tripWhen|date('d/m/Y H:i') : '—' }}</td>
                    <td>{{ report.createdAt ? report.createdAt|date('d/m/Y H:i') : '—' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8">Aucun signalement à afficher.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if report_list_total_pages > 1 %}
        <nav class="pagination-bar" aria-label="Pagination de la liste des signalements">
            {% set base_q = report_list_filter_query %}
            {% if report_list_page > 1 %}
                <a rel="prev" class="btn btn--secondary" href="{{ path('app_report_index', base_q|merge({ page: report_list_page - 1 })) }}">Page précédente</a>
            {% else %}
                <span class="pagination-bar__spacer" aria-hidden="true"></span>
            {% endif %}
            <span class="pagination-bar__status">Page {{ report_list_page }} / {{ report_list_total_pages }}</span>
            {% if report_list_page < report_list_total_pages %}
                <a rel="next" class="btn btn--secondary" href="{{ path('app_report_index', base_q|merge({ page: report_list_page + 1 })) }}">Page suivante</a>
            {% else %}
                <span class="pagination-bar__spacer" aria-hidden="true"></span>
            {% endif %}
        </nav>
    {% endif %}

    <div class="stack-actions">
        <a href="{{ path('app_report_new') }}" class="btn btn--secondary">Ouvrir le formulaire public (voyageurs)</a>
        <a href="{{ path('app_home') }}" class="btn btn--secondary">Tableau de bord</a>
    </div>
{% endblock %}
